javascript:(function(){let ld=document.createElement('div');ld.innerHTML='<div style="margin-bottom:10px;font-size:18px;font-weight:bold;">Сканирование...</div><div id="ym-pr" style="font-size:16px;color:#cbd5e1;font-weight:bold;margin-bottom:10px;">Найдено: 0 треков</div><div style="font-size:12px;color:#94a3b8;margin-bottom:15px;">Листайте плейлист вниз руками.<br>Как дойдете до конца, копируйте.</div>';ld.style.cssText='position:fixed;top:20px;right:20px;background:#1e293b;color:#fff;padding:20px;border-radius:12px;z-index:9999999;font-family:sans-serif;text-align:center;box-shadow:0 10px 40px rgba(0,0,0,0.8);border:1px solid #334155;';let bc=document.createElement('button');bc.innerText='Скопировать результат';bc.style.cssText='padding:10px 15px;background:#4f46e5;color:#fff;border:none;border-radius:6px;cursor:pointer;font-weight:bold;width:100%;margin-bottom:10px;';let bcl=document.createElement('button');bcl.innerText='Отмена';bcl.style.cssText='padding:8px 15px;background:#334155;color:#94a3b8;border:none;border-radius:6px;cursor:pointer;width:100%';ld.append(bc,bcl);document.body.appendChild(ld);let pr=document.getElementById('ym-pr');let tr=new Map();let tm=setInterval(()=>{document.querySelectorAll('div[class*="Track_root"], div.d-track').forEach(n=>{let t=n.querySelector('a[href*="/track/"]');let a=n.querySelectorAll('a[href*="/artist/"]');if(t){let title=t.innerText.trim();let link=t.href.split('?')[0];let artists=Array.from(a).map(x=>x.innerText.trim()).join(', ');tr.set(link,{title,link,artists});}});pr.innerText='Найдено: '+tr.size+' треков';},400);bc.onclick=()=>{clearInterval(tm);let res='';let i=1;tr.forEach((v)=>{res+=i+'. '+(v.artists?v.artists+' — ':'')+v.title+' ('+v.link+')\n';i++;});if(!res)alert('Треки не найдены');else{navigator.clipboard.writeText(res);bc.innerText='Скопировано ('+tr.size+')!';bc.style.background='#10b981';setTimeout(()=>document.body.removeChild(ld),2000)}};bcl.onclick=()=>{clearInterval(tm);document.body.removeChild(ld)};})();
